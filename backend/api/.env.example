# =================================================================
# 项目基础配置 (Project Basic Settings)
# =================================================================
PROJECT_NAME="星纹 AI 手相 API"

# =================================================================
# 数据库配置 (Database Settings)
# =================================================================
DB_DRIVER="mysql+aiomysql"
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER="user"
DB_PASSWORD="password"
DB_NAME="xingwen"

# =================================================================
# Redis 配置 (Redis Settings)
# =================================================================
REDIS_HOST="localhost"
REDIS_PORT=6379

# =================================================================
# 安全与加密 (Security & Auth)
# =================================================================
# 建议在生产环境中使用生成的随机字符串
SECRET_KEY="your-super-secret-key-here"
ALGORITHM="HS256"

# =================================================================
# AI 模型配置 (AI Model Settings)
# =================================================================
AI_API_KEY="your-api-key-here"
AI_BASE_URL="https://api.example.com/v1"
AI_MODEL="gemini-3-flash-preview"
